{
  "name": "@margin-call/mcp-server",
  "version": "0.1.0-phase1",
  "description": "Margin Call MCP server — Phase 1 (read-only get_desk). Lets Claude Code (or any MCP client) inspect a per-desk wallet, balances, trader counts, open deals, and recent P&L using a scoped mc_live_* API key.",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "margin-call-mcp": "src/index.ts"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "margin-call",
    "trading",
    "ai-agent"
  ],
  "license": "MIT"
}
