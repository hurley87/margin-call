# Convex
NEXT_PUBLIC_CONVEX_URL=       # From `npx convex dev` or Convex dashboard (e.g. https://xxx.convex.cloud)
CONVEX_DEPLOYMENT=            # Deployment name (e.g. dev:xxx) — set by `npx convex dev` in .env.local
CONVEX_DEPLOY_KEY=            # Required by Next.js API routes that call internal Convex functions (createConvexAdminClient). Generate with: `npx convex deployment token create local-dev --save-env`

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=    # Privy app ID; dashboard must enable Email OTP and Embedded Wallets
PRIVY_APP_SECRET=            # Server auth secret; dashboard must enable gas sponsorship for Base Sepolia

# OpenAI
OPENAI_API_KEY=

# CoinGecko (newswire price data) — free Demo tier works for the onchain endpoints.
# Convex env var: set via `npx convex env set COINGECKO_API_KEY "CG-xxxx"`.
COINGECKO_API_KEY=

# Newswire tweet posting. Leave unset/0 for dry-run (default; v1 never posts).
# Set to 1 only once a real X client is wired into convex/wire/tweetPoster.ts.
MC_WIRE_TWEETS_LIVE=

# Resend transactional email
RESEND_API_KEY=               # Convex env var — required for wipeout emails from admin@margincall.fun

# Coinbase CDP
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=          # Required for CDP SDK wallet signing

# Payments
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS=

# Agent Runtime
NEXT_PUBLIC_APP_URL=         # Base URL for internal API calls (e.g. http://localhost:3000)
CRON_SECRET=                 # Bearer for /api/narrative/generate and /api/agent/scheduler (Vercel Cron)

# RPC
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=   # Base Sepolia JSON-RPC endpoint (e.g. Alchemy, QuickNode)

# Escrow operator (server-only; must match contract operator)
OPERATOR_PRIVATE_KEY=        # Private key for enterDeal / resolveEntry on MarginCallEscrow
NEXT_PUBLIC_ESCROW_ADDRESS=  # MarginCallEscrow on Base Sepolia (set by pnpm deploy:escrow)
ESCROW_ADDRESS=              # Same as NEXT_PUBLIC_ESCROW_ADDRESS — set in Convex env too
OPERATOR_SECRET=             # Shared secret for admin endpoints (e.g. resolve-pending)

# Operator console — set via: npx convex env set OPERATOR_SUBJECTS "did:privy:xxx,did:privy:yyy"
# Comma-separated Privy subject IDs. Controls access to /admin/wire and gated Convex actions.
OPERATOR_SUBJECTS=           # (Convex env var — set in Convex dashboard or CLI, not .env.local)

# Upstash Redis (rate limiting) — optional for local dev (uses in-memory fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=           # For source map uploads
SENTRY_ORG=
SENTRY_PROJECT=

# MCP Phase 2 (desk identity, CDP server wallets per key, sync_wallet + full read surface)
# Generate strong random values (e.g. openssl rand -hex 32)
MCP_API_KEY_SECRET=          # HMAC secret for hashing mc_live_* keys before DB storage/lookup. REQUIRED for /api/mcp/keys and all /api/mcp/* routes. Same value in Convex env.
MCP_SERVICE_TOKEN=           # Shared secret for Next.js → Convex /mcp/* HTTP actions (the read-only ones). Must match exactly in .env.local + Convex (dev + prod).
