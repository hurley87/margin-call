# Convex
NEXT_PUBLIC_CONVEX_URL=       # From `npx convex dev` or Convex dashboard (e.g. https://xxx.convex.cloud)
CONVEX_DEPLOYMENT=            # Deployment name (e.g. dev:xxx) — set by `npx convex dev` in .env.local
CONVEX_DEPLOY_KEY=            # Secret deploy key for server-side admin client (never expose to browser)

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# OpenAI
OPENAI_API_KEY=

# Coinbase CDP
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=          # Required for CDP SDK wallet signing

# Payments
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS=

# Agent Runtime
NEXT_PUBLIC_APP_URL=         # Base URL for internal API calls (e.g. http://localhost:3000)

# RPC
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=   # Base Sepolia JSON-RPC endpoint (e.g. Alchemy, QuickNode)

# Escrow operator (server-only; must match contract operator)
OPERATOR_PRIVATE_KEY=        # Private key for enterDeal / resolveEntry on MarginCallEscrow
OPERATOR_SECRET=             # Shared secret for admin endpoints (e.g. resolve-pending)

# Upstash Redis (rate limiting) — optional for local dev (uses in-memory fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=           # For source map uploads
SENTRY_ORG=
SENTRY_PROJECT=
