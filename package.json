{
  "name": "mc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": "22.x",
    "pnpm": "10.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/check-convex-codegen.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check:codegen": "node scripts/check-convex-codegen.mjs",
    "check:ci": "pnpm check:codegen && pnpm lint && pnpm typecheck",
    "test": "vitest run",
    "test:convex": "vitest run tests/convex",
    "test:contracts": "cd contracts && forge test --no-match-path 'test/fork/**'",
    "test:contracts:ci": "cd contracts && FOUNDRY_PROFILE=ci forge test --no-match-path 'test/fork/**'",
    "test:contracts:fork": "cd contracts && forge test --match-path 'test/fork/**'",
    "install:forge-deps": "bash scripts/install-forge-deps.sh",
    "audit:prod": "pnpm audit --prod --audit-level=high",
    "audit:all": "pnpm audit --audit-level=high",
    "audit:all:gated": "node scripts/audit-all-gated.mjs",
    "seed:wire": "convex run seasons:importSeason",
    "prepare": "husky",
    "deploy:escrow": "tsx scripts/deploy-escrow.ts",
    "deploy:margincall-token": "tsx scripts/deploy-margincall-token.ts",
    "deploy:seat-vault": "tsx scripts/deploy-seat-vault.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@buildersgarden/siwa": "^0.0.24",
    "@coinbase/cdp-sdk": "^1.52.0",
    "@privy-io/react-auth": "^3.35.0",
    "@privy-io/server-auth": "^1.32.5",
    "@privy-io/wagmi": "^4.0.14",
    "@sentry/nextjs": "^10.65.0",
    "@tanstack/react-query": "^5",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.10",
    "openai": "^6.46.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.55.1",
    "wagmi": "^3.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.10",
    "convex-test": "^0.0.54",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "4.1.10"
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.16.0",
      "ws@<8": ">=7.5.11",
      "ws@>=8": ">=8.21.0",
      "form-data": ">=4.0.6",
      "flatted": ">=3.4.2",
      "path-to-regexp@>=8": ">=8.4.0",
      "hono": ">=4.12.25",
      "socket.io-parser": ">=4.2.6",
      "h3": ">=1.15.6",
      "defu": ">=6.1.5",
      "js-cookie": ">=3.0.7",
      "lodash": ">=4.18.0",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4"
    }
  }
}
